# ── Required ──────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Optional tool keys ────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here    # web_search primary provider (get at tavily.com)
SERPAPI_KEY=your-serpapi-key-here          # web_search fallback (get at serpapi.com)

# ── Infrastructure ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
MONGO_URI=mongodb://localhost:27017
MONGO_DB=agentdb

# ── Worker config ─────────────────────────────────────────
WORKER_COUNT=3
MAX_CONCURRENT_RUNS=10

# ── CORS ──────────────────────────────────────────────────
# WARNING: set to false in production — allows all origins when true
DEV_MODE=true
